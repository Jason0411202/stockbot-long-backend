# === MariaDB（docker compose 啟動時用來初始化資料庫） ===
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=StockLongData
MARIADB_USER=exampleuser
MARIADB_PASSWORD=examplepassword

# === App 連到資料庫用的 DSN（docker compose 內部走 service name "mariadb"） ===
# 若你要在 host 直接 go run（不走 compose），把 mariadb 換成 127.0.0.1。
DB_DSN=exampleuser:examplepassword@tcp(mariadb:3306)/?multiStatements=true

# === Discord（可留空表示不使用 Discord bot） ===
DISCORD_BOT_TOKEN=
DISCORD_BOT_CHANNELID=

# === Caddy（reverse proxy + 自動 HTTPS） ===
# 行為由 SITE_ADDRESS 一個變數切換：
#   :80              → 純 HTTP，不啟動 ACME（本機開發，沒網域）
#   localhost        → HTTP + HTTPS 自簽（本機要測 HTTPS 行為）
#   your-domain.com  → HTTP + HTTPS 自動 Let's Encrypt（正式機，需要 DNS A record + 80/443 對外）
SITE_ADDRESS=:80
ACME_EMAIL=
# 對外 port（本機 80/443 被佔用時改其他，例如 8080/8443）
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# 其他非私密超參數 (追蹤股票、回測天數、策略等) 已移到 config.yaml
